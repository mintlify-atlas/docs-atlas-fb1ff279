  "keyFeatures": [
    "Header-only C++23 library with zero dependencies",
    "Type-safe memory operations with alignment support",
    "Strong types for offsets, addresses, and function signatures",
    "Binary-safe file I/O utilities",
    "Colored hexadecimal memory dumps",
    "UNIX time conversions and high-resolution timing",
    "C++ Modules support (optional)",
    "Constexpr-friendly zero-overhead abstractions"
